# PostgreSQL (Neon dev-branch или локальный Postgres.app)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# HH.ru Bearer-токен приложения для доступа к /vacancies (client_credentials).
# Получить: зарегистрируй приложение на dev.hh.ru → Мои приложения → скопируй токен.
# Без токена /vacancies возвращает 403 — данные берутся из DB (seed-fallback или HH-кэш).
HH_APP_TOKEN=""

# Секрет для подписи сессионных JWT
JWT_SECRET="change-me"

# Токен Telegram-бота (для проверки initData). Можно пусто в dev.
BOT_TOKEN=""

# AUTH_DEV=1 — включает dev-стратегию логина (provider "web") без Telegram
AUTH_DEV=1

PORT=3000
